                <key>foreground</key>
                <string>#4078F2</string>
            </dict>
        </dict>
        <dict>
            <key>name</key>
            <string>Type / class name</string>
            <key>scope</key>
            <string>entity.name.type, entity.name.class, support.type, support.class</string>
            <key>settings</key>
            <dict>
                <key>foreground</key>
                <string>#C18401</string>
            </dict>
        </dict>
        <dict>
            <key>name</key>
